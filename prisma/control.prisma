generator client {
  provider  = "prisma-client-js"
  engineType = "client"
  output    = "../src/generated/prisma-control"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  USER
}

enum MemberStatus {
  ENROLLED
  PENDING_INVITE
}

enum CompanyTenantStatus {
  PROVISIONING
  READY
  FAILED
}

model User {
  id                        String   @id @default(cuid())
  email                     String   @unique
  password                  String
  name                      String
  activeWebSessionToken     String?
  activeMobileSessionToken  String?
  mfaEnabled                Boolean  @default(false)
  mustChangePassword        Boolean  @default(false)
  mfaOtpHash                String?
  mfaOtpExpiresAt           DateTime?
  mfaOtpAttempts            Int      @default(0)
  emailBookingNotifications Boolean  @default(true)
  calendarFeedToken         String?  @unique
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  companyMembers CompanyMember[]
}

model Company {
  id        String   @id @default(cuid())
  name      String
  domain    String?
  joinCode  String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members CompanyMember[]
  tenant  CompanyTenant?
}

model CompanyMember {
  id        String       @id @default(cuid())
  userId    String
  companyId String
  role      Role         @default(USER)
  status    MemberStatus @default(PENDING_INVITE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([companyId])
  @@index([userId])
}

model CompanyTenant {
  id                 String              @id @default(cuid())
  companyId          String              @unique
  provider           String              @default("neon")
  databaseUrl        String
  branchId           String?
  branchName         String?
  databaseName       String?
  provisioningStatus CompanyTenantStatus @default(PROVISIONING)
  provisioningError  String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}
