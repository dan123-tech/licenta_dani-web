# Self-signed dev certificate: localhost + loopback + Android emulator host alias.
# Add your PC's LAN IP as IP.3 = 192.168.x.x if phones on Wi‑Fi must trust the same cert.

[req]
default_bits = 2048
prompt = no
default_md = sha256
distinguished_name = dn
x509_extensions = v3_req

[dn]
CN = localhost
O = Dev
OU = Local HTTPS

[v3_req]
basicConstraints = CA:FALSE
keyUsage = digitalSignature, keyEncipherment
extendedKeyUsage = serverAuth
subjectAltName = @alt_names

[alt_names]
DNS.1 = localhost
IP.1 = 127.0.0.1
IP.2 = ::1
IP.3 = 10.0.2.2
