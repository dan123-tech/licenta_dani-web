# Copy to .env and adjust. Used when running `npm run dev` on the host (not inside Docker).

# Auth: REQUIRED for login — session cookie signing. Min 32 characters or login returns 503.
# Generate: openssl rand -base64 32
# AUTH_SECRET=paste-a-long-random-string-at-least-32-chars-here

# Public site URL (optional, for calendar UID host in .ics and invite links in emails)
# NEXT_PUBLIC_APP_URL=https://your-domain.com

# --- Stripe (optional, for pricing checkout) ---
# Server-side secret key (required to create Checkout sessions)
# STRIPE_SECRET_KEY=sk_test_xxx
#
# Public plan price IDs (used by the pricing page)
# NEXT_PUBLIC_STRIPE_PRICE_PROFESSIONAL=price_xxx
# NEXT_PUBLIC_STRIPE_PRICE_ENTERPRISE=price_xxx
#
# Optional: set canonical app URL for Stripe redirect URLs (otherwise uses request origin)
# APP_URL=https://your-domain.com

# Optional: override Android download link on /download (default is same-site /downloads/fleetshare.apk).
# Put your built APK at public/downloads/fleetshare.apk and commit or upload with deploy.
# NEXT_PUBLIC_ANDROID_DOWNLOAD_URL=https://cdn.example.com/FleetShare.apk

# OpenAPI base URL (defaults to http://localhost:3100). Match public URL when using a tunnel / prod.
# NEXTAUTH_URL=http://localhost:3100

# Transactional email (Resend — https://resend.com). Verify your domain, then use e.g. no-reply@yourdomain.com
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=no-reply@yourdomain.com
# EMAIL_FROM_NAME=FleetShare

# Cron: POST /api/cron/reservation-push-reminders with Authorization: Bearer <CRON_SECRET>
# Requires FIREBASE_SERVICE_ACCOUNT_JSON or GOOGLE_APPLICATION_CREDENTIALS for FCM.
# CRON_SECRET=
#
# ITP cron: POST /api/cron/itp-expiry-reminders with Authorization: Bearer <CRON_SECRET>
# ITP_REMINDER_DAYS=30
# ITP_AUTO_BLOCK_EXPIRED=true

# Local prod build over HTTP: set to 1 to omit HSTS (avoid browser sticking to HTTPS on localhost)
# DISABLE_HSTS=1

# Licence validation AI backend
# Vercel (recommended): point to ai-driving-licence-llm-cloudflare service base URL.
# Example:
# AI_DRIVING_LICENCE_LLM_CLOUDFLARE_URL=https://<your-cloudflare-ai-backend-domain>
# Face-recognition backend (Vercel example):
# AI_FACE_RECOGNITION_URL=https://ai-face-recognition-nine.vercel.app
# AI_FACE_RECOGNITION_VERIFY_PATH=/verify
# If your AI backends are protected (e.g. Vercel deployment protection), set one of:
# AI_BACKEND_AUTHORIZATION=Bearer <token>
# AI_BACKEND_BYPASS_TOKEN=<vercel-protection-bypass-token>
# Or per-service variants:
# AI_DRIVING_LICENCE_AUTHORIZATION=Bearer <token>
# AI_DRIVING_LICENCE_BYPASS_TOKEN=<token>
# AI_FACE_RECOGNITION_AUTHORIZATION=Bearer <token>
# AI_FACE_RECOGNITION_BYPASS_TOKEN=<token>
# Session flow (/api/session-create + /api/session-verify on the face backend) — off by default:
# AI_FACE_RECOGNITION_USE_SESSION_FLOW=false
#
# If the external face API fails, optional Amazon Rekognition fallback:
# AWS_REGION=eu-central-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REKOGNITION_MIN_SIMILARITY=80
# IDENTITY_FACE_REKOGNITION_FALLBACK=true
#
# Incident email attachments (admin notification) — optional
# INCIDENT_EMAIL_ATTACHMENTS=false
# INCIDENT_EMAIL_ATTACHMENTS_MAX_BYTES=7000000
# INCIDENT_EMAIL_ATTACHMENTS_MAX_FILES=5
#
# Local Docker fallback (kept for development):
AI_VERIFICATION_URL=http://localhost:8080
AI_VERIFY_PATH=/validate
# Optional face-match endpoint path if your Cloudflare backend exposes it:
# AI_FACE_MATCH_PATH=/face-match
# If the validator returns 422, try: AI_VERIFY_FORM_FIELD=image
# AI_VERIFY_FORM_FIELD=file
# Mobile selfie capture session (Veriff-style flow)
# MOBILE_CAPTURE_SESSION_TTL_MINUTES=15
# MOBILE_CAPTURE_RATE_LIMIT_WINDOW_MINUTES=5
# MOBILE_CAPTURE_RATE_LIMIT_MAX=3

# Help-Bot (FleetStream / your chat service on the host)
HELPBOT_URL=http://localhost:8501

# Database — required
#
# Local Docker / single Postgres: use the SAME value for both (see docs/DATABASE.md).
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/company_car_sharing?schema=public
# DIRECT_URL=postgresql://postgres:postgres@localhost:5432/company_car_sharing?schema=public
#
# Neon (https://neon.tech): dashboard → Connect → Prisma, or Cursor/VS Code Neon extension after Sign In.
# - DATABASE_URL = "Pooled connection" string (ends with -pooler.* or pooler endpoint)
# - DIRECT_URL   = "Direct connection" string (non-pooler host, for prisma migrate)
# The Neon extension may paste only one URL — add the other from the dashboard (Prisma needs both).
# Add ?schema=public if not already in the string. Neon URLs usually include ssl.
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&schema=public
# DIRECT_URL=postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require&schema=public
#
# Tenant provisioning (database-per-company on Neon)
# NEON_API_KEY=
# NEON_PROJECT_ID=
# NEON_ROLE_NAME=neondb_owner
# Safety valve for incidents only (default false). Keep false to enforce one DB per company.
# ALLOW_TENANT_FALLBACK=false
# Optional, defaults to br-main:
# NEON_ROOT_BRANCH_ID=br-main
#
# Vercel: paste the same DATABASE_URL + DIRECT_URL into Project → Settings → Environment Variables
# (both required for `prisma migrate deploy` on build). See README "Vercel + Neon".
#
# --- Security (see docs/SECURITY.md) ---
# Cloudflare Worker: bind KV as RATE_LIMIT_KV for auth rate limits (login/register/MFA). Without it, Postgres AuthRateLimit is used.
# AUTH_RATE_LIMIT_ENABLED=1
# AUTH_RATE_LIMIT_WINDOW_SEC=900
# AUTH_RATE_LOGIN_FAIL_IP_MAX=10
# AUTH_RATE_LOGIN_FAIL_EMAIL_MAX=25
# AUTH_RATE_REGISTER_IP_MAX=20
# AUTH_RATE_REGISTER_EMAIL_MAX=8
#
# Per-account lockout after failed password attempts (control DB). Logged server-side as JSON lines (login_failure).
# LOGIN_LOCKOUT_MAX_ATTEMPTS=5
# LOGIN_LOCKOUT_MINUTES=15
#
# All /api/* routes: max requests per IP per minute (in-process; use a WAF for strict global limits on serverless).
# API_RATE_LIMIT_ENABLED=1
# API_RATE_LIMIT_PER_MINUTE=120
#
# Web dashboard: auto sign-out after N minutes with no mouse/keyboard/scroll (client-side). Build must see the var.
# NEXT_PUBLIC_WEB_IDLE_LOGOUT_MINUTES=30
#
# Public contact form (/contact): recipient inbox (Resend still needs RESEND_API_KEY + EMAIL_FROM).
# CONTACT_FORM_TO=you@yourdomain.com
