# Copy to .env and adjust. Used when running `npm run dev` on the host (not inside Docker).

# Auth: REQUIRED for login — session cookie signing. Min 32 characters or login returns 503.
# Generate: openssl rand -base64 32
# AUTH_SECRET=paste-a-long-random-string-at-least-32-chars-here

# Public site URL (optional, for calendar UID host in .ics and invite links in emails)
# NEXT_PUBLIC_APP_URL=https://your-domain.com

# OpenAPI base URL (defaults to http://localhost:3100). Match public URL when using a tunnel / prod.
# NEXTAUTH_URL=http://localhost:3100

# Transactional email (Resend — https://resend.com). Verify your domain, then use e.g. no-reply@yourdomain.com
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=no-reply@yourdomain.com
# EMAIL_FROM_NAME=FleetShare

# Cron: POST /api/cron/reservation-push-reminders with Authorization: Bearer <CRON_SECRET>
# Requires FIREBASE_SERVICE_ACCOUNT_JSON or GOOGLE_APPLICATION_CREDENTIALS for FCM.
# CRON_SECRET=

# Local prod build over HTTP: set to 1 to omit HSTS (avoid browser sticking to HTTPS on localhost)
# DISABLE_HSTS=1

# Vercel Blob — driving licence uploads on Vercel (read-only disk). Prefer a Private store (PII).
# Omit locally/Docker to use public/uploads on disk instead.
# Cloudflare Workers (OpenNext): set the same token on the Worker (Variables / wrangler secret); Vercel-only env is not enough.
# BLOB_READ_WRITE_TOKEN=
# Must match store type at creation: private (default) or public — see Vercel Blob docs.
# BLOB_PUT_ACCESS=private

# Licence validation AI (must match your validator container port/path)
AI_VERIFICATION_URL=http://localhost:8080
AI_VERIFY_PATH=/validate
# If the validator returns 422, try: AI_VERIFY_FORM_FIELD=image
# AI_VERIFY_FORM_FIELD=file

# Help-Bot (FleetStream / your chat service on the host)
HELPBOT_URL=http://localhost:8501

# Database — required
#
# Local Docker / single Postgres: use the SAME value for both (see docs/DATABASE.md).
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/company_car_sharing?schema=public
# DIRECT_URL=postgresql://postgres:postgres@localhost:5432/company_car_sharing?schema=public
#
# Neon (https://neon.tech): dashboard → Connect → Prisma, or Cursor/VS Code Neon extension after Sign In.
# - DATABASE_URL = "Pooled connection" string (ends with -pooler.* or pooler endpoint)
# - DIRECT_URL   = "Direct connection" string (non-pooler host, for prisma migrate)
# The Neon extension may paste only one URL — add the other from the dashboard (Prisma needs both).
# Add ?schema=public if not already in the string. Neon URLs usually include ssl.
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&schema=public
# DIRECT_URL=postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require&schema=public
#
# Vercel: paste the same DATABASE_URL + DIRECT_URL into Project → Settings → Environment Variables
# (both required for `prisma migrate deploy` on build). See README "Vercel + Neon".
