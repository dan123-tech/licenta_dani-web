{
  "name": "company-car-sharing-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "certs:local": "node scripts/generate-local-certs.js",
    "dev": "concurrently --kill-others-on-fail \"npx next dev -H 0.0.0.0 -p 3100\" \"node proxy-3001.js\"",
    "dev:https": "npx next dev -H 0.0.0.0 -p 3100 --experimental-https-key deploy/certs/key.pem --experimental-https-cert deploy/certs/cert.pem",
    "dev:altproxy": "concurrently --kill-others-on-fail \"npx next dev -H 0.0.0.0 -p 3100\" \"node scripts/run-proxy-with-port.js 3010\"",
    "dev:3100": "npx next dev -H 0.0.0.0 -p 3100",
    "dev:3110": "npx next dev -H 0.0.0.0 -p 3110",
    "proxy": "node proxy-3001.js",
    "build": "node scripts/run-build.js",
    "build:cf": "opennextjs-cloudflare build",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "start": "concurrently --kill-others-on-fail \"next start -H 0.0.0.0 -p 3100\" \"node proxy-3001.js\"",
    "start:3100": "next start -H 0.0.0.0 -p 3100",
    "start:docker": "next start -H 0.0.0.0",
    "start:3110": "next start -H 0.0.0.0 -p 3110",
    "lint": "eslint",
    "populatedb": "node scripts/populate-db.js",
    "seed": "node scripts/seed-users-and-cars.js",
    "seed:maintenance": "node scripts/seed-maintenance-all-cars.js",
    "reset-password": "node scripts/reset-user-password.js",
    "seed-sqlserver": "node scripts/seed-sqlserver.js",
    "docker:dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up --build",
    "docker:prod": "docker compose up -d --build"
  },
  "dependencies": {
    "@aws-sdk/client-rekognition": "^3.1028.0",
    "@neondatabase/serverless": "^1.0.2",
    "@opennextjs/cloudflare": "^1.19.0",
    "@prisma/adapter-neon": "^6.19.3",
    "@prisma/client": "^6.19.3",
    "@vercel/blob": "^2.3.3",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.1",
    "firebase-admin": "^13.6.1",
    "jose": "^6.2.2",
    "jspdf": "^4.1.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.577.0",
    "mssql": "^12.2.0",
    "next": "16.2.3",
    "qrcode.react": "^4.2.0",
    "react": "19.2.5",
    "react-big-calendar": "^1.19.4",
    "react-dom": "19.2.5",
    "recharts": "^3.7.0",
    "swagger-ui-react": "^5.32.2",
    "ws": "^8.20.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "javascript-obfuscator": "^5.4.1",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "typescript": "~5.9.3",
    "webpack-obfuscator": "^3.6.1",
    "wrangler": "^4.81.1"
  }
}
