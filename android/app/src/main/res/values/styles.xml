<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Section title  -->
    <style name="SectionTitle">
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:letterSpacing">-0.02</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">8dp</item>
    </style>

    <!-- Page subtitle / muted text -->
    <style name="SubtitleText">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/on_surface_variant</item>
    </style>

    <!-- White card (matches web card background) -->
    <style name="AppCard" parent="">
        <item name="cardBackgroundColor">@color/card_bg</item>
        <item name="cardCornerRadius">14dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/divider</item>
        <item name="strokeWidth">1dp</item>
        <item name="contentPadding">16dp</item>
    </style>

    <!-- Stat / KPI card -->
    <style name="StatCard" parent="">
        <item name="cardBackgroundColor">@color/card_bg</item>
        <item name="cardCornerRadius">14dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/divider</item>
        <item name="strokeWidth">1dp</item>
        <item name="contentPadding">16dp</item>
    </style>

    <!-- Primary filled button -->
    <style name="PrimaryButton">
        <item name="android:textColor">@color/on_accent</item>
        <item name="backgroundTint">@color/accent</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <!-- Outlined input box themed with primary -->
    <style name="AppInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/primary</item>
        <item name="hintTextColor">@color/on_surface_variant</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>
</resources>
