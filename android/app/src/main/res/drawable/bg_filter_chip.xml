<?xml version="1.0" encoding="utf-8"?>
<!-- Background for filter chips: blue pill when selected, light grey when not -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/join_badge_bg" />
            <stroke android:width="1dp" android:color="@color/join_badge_border" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/surface_variant" />
            <stroke android:width="1dp" android:color="@color/outline" />
            <corners android:radius="20dp" />
        </shape>
    </item>
</selector>
