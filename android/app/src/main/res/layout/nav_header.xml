<?xml version="1.0" encoding="utf-8"?>
<!--
  Sidebar header: matches the web Sidebar brand block + user footer pattern.
  Top block: FleetShare mark + wordmark.
  Bottom block: user avatar initial + name + role (populated by MainActivity).
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/sidebar_bg"
    android:orientation="vertical">

    <!-- Brand row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="20dp"
        android:paddingBottom="16dp">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:contentDescription="@string/brand_name"
            android:importantForAccessibility="yes"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_brand_mark" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="10dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/brand_word_fleet"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.02" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/brand_word_share"
                    android:textColor="@color/brand_share_accent"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.02" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/brand_tagline"
                android:textColor="#59FFFFFF"
                android:textSize="10sp"
                android:layout_marginTop="1dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#0FFFFFFF" />

    <!-- User footer row (populated from code) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <!-- Avatar initial -->
        <TextView
            android:id="@+id/nav_header_avatar"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@color/brand_primary"
            android:gravity="center"
            android:text="@string/avatar_initial_user"
            android:textColor="@color/brand_icon_fg"
            android:textSize="11sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="10dp">

            <TextView
                android:id="@+id/nav_header_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/unknown_user_placeholder"
                android:textColor="#E6FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/nav_header_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#59FFFFFF"
                android:textSize="10sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
