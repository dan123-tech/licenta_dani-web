<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">
        <!-- Row 1: User name (ellipsize) + Role chip -->
        <TextView
            android:id="@+id/user_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/on_surface"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/user_role"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintHorizontal_chainStyle="packed"
            android:layout_marginEnd="8dp"
            tools:text="User Name" />
        <TextView
            android:id="@+id/user_role"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="40dp"
            android:gravity="center"
            android:textSize="11sp"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:background="@color/surface_variant"
            android:textColor="@color/on_surface_variant"
            app:layout_constraintStart_toEndOf="@id/user_title"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/user_title"
            app:layout_constraintBottom_toBottomOf="@id/user_title"
            tools:text="ADMIN" />
        <!-- Row 2: Email (ellipsize) -->
        <TextView
            android:id="@+id/user_subtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textSize="13sp"
            android:textColor="@color/on_surface_variant"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/user_title"
            tools:text="user@example.com · DL: APPROVED" />
        <!-- Row 3: Action buttons in horizontal group -->
        <LinearLayout
            android:id="@+id/user_actions"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:baselineAligned="false"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/user_subtitle">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/user_role_btn"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/role_label"
                android:textSize="11sp"
                android:textColor="@color/accent"
                app:autoSizeTextType="uniform"
                app:autoSizeMinTextSize="8sp"
                app:autoSizeMaxTextSize="11sp"
                app:backgroundTint="@android:color/transparent"
                app:minWidth="0dp"
                app:paddingStart="4dp"
                app:paddingEnd="4dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/user_approve_dl"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/approve_dl"
                android:textSize="11sp"
                android:textColor="@color/accent"
                app:autoSizeTextType="uniform"
                app:autoSizeMinTextSize="8sp"
                app:autoSizeMaxTextSize="11sp"
                app:backgroundTint="@android:color/transparent"
                app:minWidth="0dp"
                app:paddingStart="4dp"
                app:paddingEnd="4dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/user_reject_dl"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/reject_dl"
                android:textSize="11sp"
                android:textColor="@color/error"
                app:autoSizeTextType="uniform"
                app:autoSizeMinTextSize="8sp"
                app:autoSizeMaxTextSize="11sp"
                app:backgroundTint="@android:color/transparent"
                app:minWidth="0dp"
                app:paddingStart="4dp"
                app:paddingEnd="4dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/user_remove"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/remove"
                android:textSize="11sp"
                android:textColor="@color/error"
                app:autoSizeTextType="uniform"
                app:autoSizeMinTextSize="8sp"
                app:autoSizeMaxTextSize="11sp"
                app:backgroundTint="@android:color/transparent"
                app:minWidth="0dp"
                app:paddingStart="4dp"
                app:paddingEnd="4dp" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
