<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- HTTP to your dev PC on LAN (e.g. 192.168.x.x). Use HTTPS in production. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
